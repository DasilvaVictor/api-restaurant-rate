# ==============================================================
# Variables de entorno para el perfil de PRODUCCION (prod)
# ==============================================================
#
# --- DESPLIEGUE EN RAILWAY ---
# 1. Agrega el plugin "PostgreSQL" a tu proyecto en Railway.
# 2. En el servicio de la API, define estas variables usando
#    referencias al plugin Postgres (sintaxis ${{Postgres.VAR}}):
#
#      SPRING_PROFILES_ACTIVE = prod
#      DB_URL      = jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
#      DB_USERNAME = ${{Postgres.PGUSER}}
#      DB_PASSWORD = ${{Postgres.PGPASSWORD}}
#      JWT_SECRET  = <secreto aleatorio de al menos 32 caracteres>
#
#    Railway inyecta PORT automaticamente; la app ya lo usa.
#
# --- EJECUCION LOCAL (docker / mvn) ---
# Copia este archivo a .env y completa los valores. NO subir .env al repo.
# ==============================================================

# Perfil activo
SPRING_PROFILES_ACTIVE=prod

# --- Base de datos PostgreSQL ---
DB_URL=jdbc:postgresql://localhost:5432/restaurant_rate_db
DB_USERNAME=restaurant_user
DB_PASSWORD=cambia-esta-clave
DB_POOL_SIZE=10
DB_POOL_MIN_IDLE=2

# --- JWT ---
# Debe tener al menos 32 caracteres (256 bits) para HS256.
JWT_SECRET=genera-un-secreto-largo-y-aleatorio-de-al-menos-32-caracteres
JWT_EXPIRATION=86400000

# --- Usuario administrador por defecto ---
# Se crea al arrancar si no existe. Cambia la contrasena en produccion.
ADMIN_NOMBRE=Victor
ADMIN_EMAIL=chirinosdasilva@gmail.com
ADMIN_PASSWORD=cambia-esta-clave-en-produccion
